{
  "name": "rallytech",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "capture:local:home": "node scripts/capture-page.mjs --url http://127.0.0.1:3000/ --slug home --out pentagonClone/captures/local",
    "capture:reference:home": "node scripts/capture-page.mjs --url https://pentagoneng.com/ --slug home --out pentagonClone/captures/reference",
    "capture:reference:pages": "node scripts/capture-reference-pages.mjs",
    "dev": "nuxt dev",
    "generate:i18n-reference-pages": "node scripts/generate-i18n-reference-pages.mjs",
    "nano:hero:generate": "node scripts/generate-home-hero-candidate.mjs",
    "nano:hero:promote": "node scripts/promote-home-hero-candidate.mjs",
    "migrate:image-assets:phase2": "node scripts/migrate-active-image-assets-to-canonical-paths.mjs",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "audit:i18n-copy": "node scripts/audit-i18n-copy.mjs",
    "audit:image-assets": "node scripts/audit-image-assets.mjs",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "guard:ui-buttons": "node scripts/check-u-button-content.mjs",
    "lint": "eslint . --ignore-pattern \"tools/codex-toolkit/skills/**\"",
    "typecheck": "nuxt typecheck",
    "verify": "npm run format:check && npm run lint && npm run guard:ui-buttons && npm run typecheck",
    "workflow:clone:preflight": "node scripts/clone-workflow-preflight.mjs"
  },
  "dependencies": {
    "@iconify-json/ic": "^1.2.4",
    "@iconify-json/lucide": "^1.2.98",
    "@nuxt/ui": "^4.5.1",
    "@nuxtjs/i18n": "10.2.4",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "eslint": "^10.0.3",
    "playwright": "^1.59.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.6"
  },
  "packageManager": "npm@11.11.0"
}
